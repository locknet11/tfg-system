# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

region  = "us-east-1"
project = "tfg-central"

ssh_public_key = "ssh-ed25519 AAAA... you@host"
admin_cidr     = "203.0.113.7/32" # curl -s ifconfig.me

instance_type = "t3.small"

# Domains — create A records for BOTH pointing at this instance's public IP (see outputs).
ui_domain  = "tfg.locknet.com.ar"
api_domain = "tfg-api.locknet.com.ar"

# MongoDB Atlas connection string. Add this instance's public IP to Atlas Network Access.
mongodb_uri           = "mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
mongodb_database_name = "tfg-system"

# JWT signing secret. Leave empty to auto-generate a stable random one, or pin your own.
jwt_secret = ""

# Optional integrations (leave empty to disable)
# resend_api_key      = ""
# resend_from_address = ""
# nvd_api_key         = ""
# central_public_key      = ""
# replication_private_key = ""

# Images are public (no pull token). Override only if you push elsewhere.
# api_image = "registry.locknet.com.ar/tfg/api"
# ui_image  = "registry.locknet.com.ar/tfg/ui"

allocate_eip = true
